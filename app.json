{
  "expo": {
    "name": "TuneScore",
    "slug": "tunescore",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tunescore.app"
    },
    "android": {
      "package": "com.tunescore.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "anthropicApiKey": "INJECTED_AT_BUILD",
      "eas": {
        "projectId": ""
      }
    }
  }
}
